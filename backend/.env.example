# LogiSight backend — copy to .env and fill values

# Supabase PostgreSQL (async SQLAlchemy + Alembic)
# Example: postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres

# Supabase Auth (JWT verification & admin API)
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# CORS — comma-separated origins; defaults to localhost:5173 if unset
# CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Optional: SQL echo for debugging
# SQLALCHEMY_ECHO=true

# Integrations (Phase 4+)
VERYFI_CLIENT_ID=
VERYFI_CLIENT_SECRET=
VERYFI_USERNAME=
VERYFI_API_KEY=
OPENAI_API_KEY=
